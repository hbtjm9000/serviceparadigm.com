---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-100 grid grid-cols-1 md:grid-cols-2 w-full px-12 py-16 gap-8 border-t border-slate-200">
  <!-- Brand + Social Column -->
  <div class="flex flex-col justify-between">
    <div>
      <div class="font-serif text-xl font-black text-slate-900 mb-6">
        Paradigm IT Services
      </div>
      <p class="font-serif text-sm uppercase tracking-widest text-slate-600 max-w-md leading-relaxed">
        &copy; {currentYear} Paradigm IT Services. All Rights Reserved. Built for the architecture-first enterprise.
      </p>
    </div>

    <!-- Social / Platform Icons -->
    <div class="mt-12 flex gap-6">
      <!-- Language/Globe -->
      <a href="/" aria-label="Website" class="text-slate-600 hover:text-primary transition-colors">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
      </a>
      <!-- Email -->
      <a href="/contact" aria-label="Email" class="text-slate-600 hover:text-primary transition-colors">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
      </a>
      <!-- Terminal -->
      <a href="https://www.linkedin.com/company/paradigmitjm/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-600 hover:text-primary transition-colors">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Navigation Grid -->
  <div class="grid grid-cols-2 gap-8">
    <!-- Navigation Column -->
    <div class="flex flex-col gap-4">
      <h4 class="font-body text-xs font-bold uppercase text-slate-900 mb-2">Navigation</h4>
      <a href="/about" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">About</a>
      <a href="/services" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Services</a>
      <a href="/elements" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Elements</a>
      <a href="/insights" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Insights</a>
      <a href="/contact" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Contact</a>
    </div>

    <!-- Connect Column -->
    <div class="flex flex-col gap-4">
      <h4 class="font-body text-xs font-bold uppercase text-slate-900 mb-2">Connect</h4>
      <a href="/privacy" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Privacy Policy</a>
      <a href="/terms" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Terms of Service</a>
      <a href="/accessibility" class="font-serif text-sm uppercase tracking-widest text-slate-600 hover:text-primary transition-colors">Accessibility</a>
    </div>
  </div>
</footer>
