---
interface Service {
  label: string;
  title: string;
  description: string;
  tags: string[];
}

const services: Service[] = [
  {
    label: "AI Architecture",
    title: "AI Strategy",
    description: "We map your organisation's readiness, identify high-impact automation opportunities, and design the architecture to execute. Not a chatbot. A system that works.",
    tags: ["[Em:AIReadiness]", "[Em:ArchitectureDesign]"]
  },
  {
    label: "Solutions",
    title: "Solutions Architecture",
    description: "From legacy modernisation to cloud-native builds — we design systems that scale, adapt, and don't create the next round of technical debt.",
    tags: ["[Cd:Cloud]", "[Zt:ModerniseElement]"]
  },
  {
    label: "Security",
    title: "Cybersecurity Architecture",
    description: "Security designed in from the start, not bolted on after a breach. We build postures that hold under pressure.",
    tags: ["[Zt:SecureElement]"]
  }
];
---

<section class="bg-surface-container-low py-32">
  <div class="max-w-7xl mx-auto px-12">
    <!-- Section Header -->
    <div class="flex justify-between items-end mb-20">
      <div>
        <span class="font-body text-xs text-primary uppercase tracking-[0.4em] mb-4 block">Core Paradigms</span>
        <h2 class="font-serif text-5xl font-black">Strategic Pillars.</h2>
      </div>
      <div class="hidden md:block w-1/3 h-[1px] bg-outline-variant mb-4"></div>
    </div>

    <!-- Services Grid - seamless cards with hover effects -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-collapse">
      {services.map((service, i) => (
        <article
          class={i === 0 ? 'bg-white p-12 hover:bg-tertiary hover:text-white transition-colors duration-500 group' :
                i === 1 ? 'bg-surface-container-high p-12 hover:bg-primary hover:text-white transition-colors duration-500 group' :
                'bg-white p-12 hover:bg-slate-900 hover:text-white transition-colors duration-500 group'}
        >
          <span class={`font-body text-xs ${i === 0 ? 'opacity-40' : i === 1 ? '' : 'opacity-40'} mb-12 block group-hover:opacity-40`}>
            {service.label}
          </span>

          <h3 class="font-serif text-3xl mb-8 group-hover:italic">
            {service.title}
          </h3>

          <p class={`font-body text-on-surface-variant group-hover:${i === 0 ? 'text-tertiary-fixed-dim' : i === 1 ? 'text-primary-fixed-dim' : 'text-slate-300'} leading-relaxed mb-12`}>
            {service.description}
          </p>

          <div class="flex flex-wrap gap-2">
            {service.tags.map((tag) => (
              <span
                class={i === 0 ? 'px-3 py-1 bg-surface-container text-[10px] font-body font-bold text-secondary group-hover:bg-white/10 group-hover:text-secondary-fixed' :
                      i === 1 ? 'px-3 py-1 bg-white/20 text-[10px] font-body font-bold uppercase group-hover:text-white' :
                      'px-3 py-1 bg-surface-container text-[10px] font-body font-bold text-secondary group-hover:bg-white/10 group-hover:text-secondary-fixed'}
              >
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
