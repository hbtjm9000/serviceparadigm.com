---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import { getServices } from '../utils/content-loader';
import { BOOKING_URL } from '../config';

const services = getServices();
---

<BaseLayout 
  title="Services — Paradigm IT Services"
  description="End-to-end IT services: digital transformation, AI consulting, and managed services for Caribbean businesses."
>
  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-surface border-b border-on-surface/10">
    <div class="max-w-7xl mx-auto px-6">
      <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">What We Offer</span>
      <h1 class="font-fraunces font-bold text-secondary text-5xl md:text-6xl leading-tight mb-6 max-w-3xl">
        Our Services
      </h1>
      <p class="font-outfit text-on-surface-variant text-xl max-w-2xl leading-relaxed">
        From AI integration to day-to-day IT management, we provide the full range of technology services your business needs to compete and grow.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-24 bg-white" aria-label="Services list">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, i) => (
          <ServiceCard 
            title={service.title}
            description={service.description}
            icon={service.icon}
            href={`/services#${service.slug}`}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-tertiary" aria-labelledby="services-cta">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 id="services-cta" class="font-fraunces font-bold text-white text-3xl md:text-4xl mb-6">
        Not sure what you need?
      </h2>
      <p class="font-outfit text-white/80 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
        Book a free 30-minute discovery call. We'll diagnose the problem and recommend next steps — no obligation.
      </p>
      <Button variant="secondary" href={BOOKING_URL} label="Book Discovery Call" icon={true} />
    </div>
  </section>
</BaseLayout>
