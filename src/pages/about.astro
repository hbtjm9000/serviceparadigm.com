---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { BOOKING_URL } from '../config';
---

<BaseLayout 
  title="About — Paradigm IT Services"
  description="Founded in Kingston, Jamaica — Paradigm IT Services brings local expertise and global best practices to Caribbean businesses."
>
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-tertiary" aria-label="About Paradigm IT">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary-fixed mb-6 block">About Us</span>
      <h1 class="font-fraunces font-bold text-white text-5xl md:text-7xl leading-tight mb-8 max-w-4xl mx-auto drop-shadow-ink">
        Engineering the Next Paradigm.
      </h1>
      <p class="font-outfit font-light text-white/80 text-xl max-w-2xl mx-auto leading-relaxed">
        Founded in Kingston, Jamaica — serving the Caribbean and beyond.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-24 bg-white" aria-labelledby="story-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
        <div>
          <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">Our Story</span>
          <h2 id="story-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight mb-8">
            From Kingston to the Caribbean
          </h2>
          <div class="space-y-6 font-outfit text-on-surface-variant text-lg leading-relaxed">
            <p>
              Paradigm IT Services was founded with a clear mission: to bring world-class IT infrastructure and AI capabilities to Caribbean businesses that have historically been locked out of enterprise-grade technology.
            </p>
            <p>
              We saw brilliant Jamaican and Caribbean entrepreneurs struggle against infrastructure gaps and talent shortages. We decided to bridge that gap — building a company that understands both the global standard of excellence and the Caribbean reality.
            </p>
            <p>
              Today, we serve businesses across Jamaica, Trinidad, Barbados, and the wider Caribbean region, with partnerships spanning North America and Europe.
            </p>
          </div>
        </div>
        
        <div class="space-y-6">
          <div class="p-8 bg-surface">
            <h3 class="font-fraunces font-semibold text-secondary text-xl mb-4">Our Mission</h3>
            <p class="font-fraunces italic text-on-surface-variant text-lg leading-relaxed">
              "To empower Caribbean businesses with the technology infrastructure they need to compete globally — delivered with local expertise and care."
            </p>
          </div>
          <div class="p-8 bg-surface">
            <h3 class="font-fraunces font-semibold text-secondary text-xl mb-4">Our Vision</h3>
            <p class="font-outfit text-on-surface-variant text-base leading-relaxed">
              A Caribbean where every business — regardless of size — has access to the tools, data, and AI capabilities needed to thrive in the digital economy.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 bg-surface" aria-labelledby="values-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">What Guides Us</span>
        <h2 id="values-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight">
          Our Values
        </h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { title: 'Integrity', desc: 'We say what we mean and deliver what we promise — every time.' },
          { title: 'Excellence', desc: 'We hold ourselves to the highest standard in everything we build.' },
          { title: 'Accessibility', desc: 'Enterprise-grade technology should not be reserved for enterprise budgets.' },
          { title: 'Partnership', desc: 'We succeed when our clients succeed. Your goals are our goals.' },
        ].map(value => (
          <div class="p-6 bg-white">
            <h3 class="font-fraunces font-semibold text-primary text-xl mb-3">{value.title}</h3>
            <p class="font-outfit text-on-surface-variant text-sm leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-secondary" aria-label="Company statistics">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        {[
          { num: '50+', label: 'Clients Served' },
          { num: '10+', label: 'Years in Business' },
          { num: '99.9%', label: 'Uptime SLA' },
          { num: '3', label: 'Countries Served' },
        ].map(stat => (
          <div>
            <p class="font-fraunces font-bold text-white text-4xl md:text-5xl mb-2">{stat.num}</p>
            <p class="font-space text-xs uppercase tracking-wider text-white/60">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-white" aria-labelledby="about-cta">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 id="about-cta" class="font-fraunces font-bold text-secondary text-3xl md:text-4xl mb-6">
        Want to work with us?
      </h2>
      <p class="font-outfit text-on-surface-variant text-lg max-w-lg mx-auto mb-10 leading-relaxed">
        We're always looking for talented people and interesting projects. Let's talk.
      </p>
      <Button href={BOOKING_URL} label="Get in Touch" icon={true} />
    </div>
  </section>
</BaseLayout>
