---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import ContactForm from '../../components/ContactForm.astro';

const features = [
  {
    title: 'Professional Website',
    description: 'A stunning 5-page responsive website that looks great on all devices.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    title: 'Custom Domain',
    description: 'Your own domain name (e.g., yourbusiness.com) professionally configured.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />`,
  },
  {
    title: 'Business Email',
    description: '5 professional email addresses (e.g., hello@yourbusiness.com).',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    title: 'SSL Security',
    description: 'Bank-grade encryption to protect your visitors and build trust.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`,
  },
  {
    title: 'SEO Setup',
    description: 'Search engine optimization to help customers find you online.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
  },
  {
    title: 'Mobile Responsive',
    description: 'Perfect viewing experience on smartphones, tablets, and desktops.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
  },
];

const pages = [
  'Home Page',
  'About Us',
  'Services/Products',
  'Contact Page',
  'Privacy Policy',
];
---

<BaseLayout title="Element - Digital Presence Starter" description="Establish your online presence with a professional website, custom domain, and business email. The perfect starting point for Caribbean businesses.">
  <Header logoVariant="mono-white" />
  <section class="bg-gradient-to-br from-primary via-primary to-secondary text-white py-28 lg:py-36">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block bg-white/20 px-4 py-2 text-sm font-mono tracking-widest uppercase mb-6">
          Digital Presence Starter
        </span>
        <h1 class="text-display-lg font-display font-bold mb-6">
          Your Business Online, Starting Today
        </h1>
        <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
          Everything you need to establish your digital presence. Professional website, custom domain, business email, and security—all included.
        </p>
        <a href="/contact" class="btn-secondary inline-block bg-white text-primary text-lg px-8 py-4">
          Get Started
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-display-sm font-display font-bold text-secondary mb-6">
            First Impressions Matter
          </h2>
          <p class="text-lg text-ink-muted mb-6">
            In today's digital world, potential customers search for businesses online before making decisions. Without a professional online presence, you are invisible to a growing number of customers.
          </p>
          <p class="text-lg text-ink-muted">
            Element gives you everything you need to establish credibility and reach customers online—without the complexity or high costs of traditional web development.
          </p>
        </div>
        <div class="bg-gray-800 p-8">
          <h3 class="text-xl font-display font-semibold text-white mb-6">With Element, you get:</h3>
          <ul class="space-y-4">
            {pages.map((page) => (
              <li class="flex items-center space-x-3">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">{page}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display font-bold text-secondary mb-4">Everything Included</h2>
        <p class="text-xl text-ink-muted max-w-2xl mx-auto">
          A complete digital presence solution for businesses starting out.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="bg-white p-6 border border-gray-200">
            <div class="w-12 h-12 bg-primary/10 flex items-center justify-center mb-4">
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" set:html={feature.icon} />
            </div>
            <h3 class="text-lg font-display font-semibold text-secondary mb-2">{feature.title}</h3>
            <p class="text-ink-muted">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-display-md font-display font-bold text-secondary mb-4">Simple Pricing</h2>
        <p class="text-xl text-ink-muted">
          One simple price. No hidden fees. No surprises.
        </p>
      </div>
      
      <div class="bg-white border-2 border-gray-200">
        <div class="bg-primary text-white p-8 text-center">
          <div class="text-5xl lg:text-6xl font-display font-bold mb-2">$997</div>
          <div class="text-xl text-white/90 font-mono">Setup + First Year</div>
        </div>
        <div class="p-8">
          <ul class="space-y-4 mb-8">
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Professional 5-page website</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Domain registration (yourbusiness.com)</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>5 professional email addresses</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>SSL security certificate</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>SEO optimization</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Mobile responsive design</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>30-day support included</span>
            </li>
          </ul>
          <a href="/contact" class="btn-primary w-full text-center block text-lg py-4">
            Get Started
          </a>
          <p class="text-center text-ink-faded text-sm mt-4 font-mono">
            Annual renewal: $299/year for hosting + domain
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-tertiary text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-display-sm font-display font-bold mb-6">Ready to Go Online?</h2>
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        Book a consultation and let's build your digital presence together.
      </p>
      <div class="max-w-xl mx-auto">
        <ContactForm title="Get Started with Element" />
      </div>
    </div>
  </section>
</BaseLayout>
