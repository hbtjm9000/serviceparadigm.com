---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { BOOKING_URL } from '../../config';
---

<BaseLayout 
  title="Elements — Paradigm IT Services"
  description="Elements: modular, reusable AI and automation building blocks for Caribbean businesses. Ship faster, scale confidently."
>
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-tertiary relative overflow-hidden" aria-label="Elements product hero">
    <div class="absolute inset-0 opacity-[0.04]" 
      style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 48px 48px;">
    </div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="max-w-3xl">
        <span class="inline-block font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary-fixed mb-6 px-3 py-1.5 border border-secondary-fixed/30">
          Product · Elements
        </span>
        <h1 class="font-fraunces font-bold text-white text-5xl md:text-7xl leading-tight mb-8 drop-shadow-ink">
          Build Fast.<br/>Scale Confidently.
        </h1>
        <p class="font-outfit font-light text-white/80 text-xl md:text-2xl leading-relaxed mb-10 max-w-2xl">
          Elements are modular AI and automation building blocks — designed so Caribbean businesses can ship production-grade systems in days, not months.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href={BOOKING_URL} label="Request Early Access" icon={true} />
          <Button variant="secondary" href={BOOKING_URL} label="Book a Demo" />
        </div>
      </div>
    </div>
  </section>

  <!-- What are Elements -->
  <section class="py-24 bg-white" aria-labelledby="what-elements">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">The Concept</span>
          <h2 id="what-elements" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight mb-8">
            Reusable Building Blocks for Modern IT
          </h2>
          <p class="font-outfit text-on-surface-variant text-lg leading-relaxed mb-6">
            Instead of building from scratch every time, Elements gives you pre-built, battle-tested components for the most common enterprise IT needs — AI inference, workflow automation, data pipelines, and more.
          </p>
          <p class="font-outfit text-on-surface-variant text-lg leading-relaxed mb-8">
            Each Element is independently deployable, composable with others, and backed by our SLA. Mix and match to build exactly what your business needs.
          </p>
          <Button variant="ghost" href={BOOKING_URL} label="Learn How It Works" icon={true} />
        </div>
        <div class="bg-surface p-8">
          <p class="font-space text-xs uppercase tracking-widest text-on-surface-variant mb-6">Available Elements</p>
          <ul class="space-y-4" role="list">
            {[
              { name: 'el-ai-inference', desc: 'One-line integration for LLM APIs — OpenAI, Anthropic, Gemini, local models.' },
              { name: 'el-workflow-orch', desc: 'Visual workflow builder with retry logic, branching, and human-in-the-loop approval.' },
              { name: 'el-data-pipeline', desc: 'ETL/ELT pipelines with connectors for Postgres, S3, Notion, and 50+ more.' },
              { name: 'el-chatbot', desc: 'RAG-powered customer service chatbot with brand voice tuning.' },
              { name: 'el-report-engine', desc: 'Scheduled report generation from any data source, delivered to email or Slack.' },
            ].map(el => (
              <li class="flex items-start gap-3">
                <code class="font-space text-xs bg-tertiary/10 text-tertiary px-2 py-1 flex-shrink-0 mt-0.5">{el.name}</code>
                <span class="font-outfit text-on-surface-variant text-sm leading-relaxed">{el.desc}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-24 bg-surface" aria-labelledby="features-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">Built for Teams</span>
        <h2 id="features-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight">
          Enterprise-Grade by Default
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { title: '99.9% SLA', desc: 'Every Element backed by our enterprise uptime guarantee. Monitored 24/7.' },
          { title: 'SOC 2 Compliant', desc: 'Built with security-first architecture. Your data never leaves your control.' },
          { title: 'Language Agnostic', desc: 'Use any language. SDKs for Python, TypeScript, Go, and REST API for everything else.' },
          { title: 'Versioned APIs', desc: 'Breaking changes are versioned. Upgrade on your schedule, not ours.' },
          { title: 'Observable', desc: 'Built-in tracing, metrics, and alerting via OpenTelemetry.' },
          { title: 'Self-Host Option', desc: 'Run Elements on your own infrastructure for data sovereignty requirements.' },
        ].map(f => (
          <div class="p-6 bg-white">
            <h3 class="font-fraunces font-semibold text-secondary text-lg mb-3">{f.title}</h3>
            <p class="font-outfit text-on-surface-variant text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-primary" aria-labelledby="elements-cta">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 id="elements-cta" class="font-fraunces font-bold text-white text-4xl md:text-5xl leading-tight mb-6">
        Ready to Build?
      </h2>
      <p class="font-outfit font-light text-white/80 text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
        Join the waitlist for early access or book a technical walkthrough with our team.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button href={BOOKING_URL} label="Request Early Access" icon={true} />
        <Button variant="secondary" href={BOOKING_URL} label="Talk to an Engineer" />
      </div>
    </div>
  </section>
</BaseLayout>
