---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.vue';
---

<BaseLayout
  title="Contact Paradigm IT Services | Schedule a Consultation"
  description="Get in touch with Paradigm IT Services. Schedule a free consultation to discuss your AI, cloud, or digital transformation project. Reach us at hal@paradigm.com.jm or (876) 890-4060."
>
  <Header logoVariant="mono-white" />
  <main id="main">
    <!-- Hero Section -->
    <section class="bg-tertiary text-on-tertiary py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <span class="font-sans text-xs tracking-[0.2em] text-secondary-fixed-dim uppercase">Get Started</span>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white leading-[1.05] mt-4 max-w-3xl text-balance">
          Start Your
          <br />
          <span class="italic text-secondary-fixed-dim">Transformation.</span>
        </h1>
        <p class="mt-8 max-w-xl text-white/70 font-body leading-relaxed text-lg">
          Ready to move to the next paradigm? Let&apos;s discuss how we can architect 
          your digital future together.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="bg-surface py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
          <!-- Contact Information -->
          <div>
            <span class="font-sans text-xs tracking-[0.2em] text-primary uppercase">Contact Information</span>
            <h2 class="font-serif text-4xl text-on-surface mt-4 leading-[1.1]">
              Let&apos;s Connect
            </h2>
            <p class="font-body text-on-surface-variant mt-6 leading-relaxed text-lg">
              Whether you&apos;re exploring AI possibilities, modernizing your infrastructure, 
              or strengthening your security posture—we&apos;re here to help.
            </p>

            <div class="mt-12 space-y-8">
              <div>
                <h3 class="font-sans text-xs tracking-[0.15em] text-on-surface-variant uppercase mb-2">Email</h3>
                <a href="mailto:hello@serviceparadigm.com" class="font-body text-lg text-on-surface hover:text-primary transition-colors">
                  hello@serviceparadigm.com
                </a>
              </div>
              
              <div>
                <h3 class="font-sans text-xs tracking-[0.15em] text-on-surface-variant uppercase mb-2">Phone</h3>
                <a href="tel:+1-555-PARADIGM" class="font-body text-lg text-on-surface hover:text-primary transition-colors">
                  +1 (555) PARADIGM
                </a>
              </div>
              
              <div>
                <h3 class="font-sans text-xs tracking-[0.15em] text-on-surface-variant uppercase mb-2">Mailing Address</h3>
                <p class="font-body text-lg text-on-surface">
                  P.O. Box 4080 Red Hills<br />
                  St. Andrew JMAAW17, Jamaica
                </p>
              </div>
            </div>

            <!-- Office Hours -->
            <div class="mt-12 p-8 bg-surface-container-low">
              <h3 class="font-sans text-xs tracking-[0.15em] text-on-surface-variant uppercase mb-4">Business Hours</h3>
              <div class="space-y-2">
                <div class="flex justify-between font-body text-on-surface">
                  <span>Monday - Friday</span>
                  <span>8:30 AM - 5:00 PM EST</span>
                </div>
                <div class="flex justify-between font-body text-on-surface-variant">
                  <span>Saturday - Sunday</span>
                  <span>Closed</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="bg-surface-container-low p-8 lg:p-12">
            <h3 class="font-serif text-2xl text-on-surface mb-8">Request Consultation</h3>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
