---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

interface Service {
  id: string;
  label: string;
  title: string;
  description: string;
  features: string[];
  image: string;
}

const services: Service[] = [
  {
    id: "ai-strategy",
    label: "AI Architecture",
    title: "AI Strategy & Implementation",
    description: "Helping organizations identify and deploy AI opportunities through comprehensive readiness assessments, architecture design, and automation systems. We guide your transformation from traditional processes to intelligent, AI-powered operations.",
    features: [
      "AI Readiness Assessments",
      "AI Architecture Design",
      "Automation Systems",
      "Machine Learning Operations",
      "Natural Language Processing",
      "Computer Vision Solutions"
    ],
    image: "/images/cloud-engineering.jpg"
  },
  {
    id: "solutions-architecture",
    label: "Solutions",
    title: "Solutions Architecture",
    description: "Designing scalable systems for modern organizations through cloud architecture, platform modernization, and integration architecture. We create technical blueprints that align with your business objectives.",
    features: [
      "Cloud Architecture",
      "Platform Modernization",
      "Integration Architecture",
      "Microservices Design",
      "API Strategy",
      "Data Architecture"
    ],
    image: "/images/privacy-paper.jpg"
  },
  {
    id: "cybersecurity",
    label: "Security",
    title: "Cybersecurity Architecture",
    description: "Designing security into systems from the beginning through zero trust architectures, security posture design, and compliance architecture. Protect your enterprise with defense-in-depth strategies.",
    features: [
      "Zero Trust Architectures",
      "Security Posture Design",
      "Compliance Architecture",
      "Identity & Access Management",
      "Threat Modeling",
      "Security Operations"
    ],
    image: "/images/security-protocol.jpg"
  }
];
---

<BaseLayout title="Services | Paradigm IT Services">
  <Header />
  <main id="main">
    <!-- Hero Section -->
    <section class="bg-tertiary text-on-tertiary py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <span class="font-sans text-xs tracking-[0.2em] text-secondary-fixed-dim uppercase">Strategic Services</span>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white leading-[1.05] mt-4 max-w-4xl text-balance">
          Architecture-First
          <br />
          <span class="italic text-secondary-fixed-dim">Solutions.</span>
        </h1>
        <p class="mt-8 max-w-xl text-white/70 font-body leading-relaxed text-lg">
          Our premium consulting services represent the strategic layer of Paradigm IT Services. 
          We don't just implement—we architect your digital future.
        </p>
      </div>
    </section>

    <!-- Services List -->
    {services.map((service, index) => (
      <section 
        id={service.id}
        class={`py-20 lg:py-28 ${index % 2 === 0 ? 'bg-surface' : 'bg-surface-container-low'}`}
      >
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
          <div class={`grid lg:grid-cols-2 gap-16 lg:gap-24 items-center ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}>
            <!-- Content -->
            <div class={index % 2 === 1 ? 'lg:col-start-2' : ''}>
              <span class="font-sans text-xs tracking-[0.2em] text-primary uppercase">{service.label}</span>
              <h2 class="font-serif text-4xl lg:text-5xl text-on-surface mt-4 leading-[1.1]">
                {service.title}
              </h2>
              <p class="font-body text-on-surface-variant mt-6 leading-relaxed text-lg">
                {service.description}
              </p>
              
              <!-- Features Grid -->
              <div class="grid grid-cols-2 gap-4 mt-8">
                {service.features.map((feature) => (
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-2 bg-secondary-fixed-dim flex-shrink-0"></div>
                    <span class="font-sans text-sm text-on-surface">{feature}</span>
                  </div>
                ))}
              </div>

              <!-- CTA -->
              <a 
                href="/contact" 
                class="inline-flex items-center gap-2 bg-primary text-on-primary font-sans text-sm px-6 py-3 mt-10 hover:bg-secondary transition-colors tracking-wide group"
              >
                <span>Schedule Consultation</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>

            <!-- Image -->
            <div class={`aspect-[4/3] bg-surface-container overflow-hidden ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
              <img 
                src={service.image} 
                alt={service.title}
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </section>
    ))}
  </main>
  <Footer />
</BaseLayout>
