---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import { getServices } from '../utils/content-loader';
import { BOOKING_URL } from '../config';

const services = getServices();
---

<BaseLayout 
  title="Paradigm IT Services — Engineering the Next Paradigm"
  description="IT solutions, digital transformation, and AI integration for Caribbean businesses. Founded in Kingston, Jamaica."
>
  <!-- Hero -->
  <Hero align="center" />

  <!-- What We Do -->
  <section class="py-24 bg-white" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">What We Do</span>
        <h2 id="services-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight mb-6">
          End-to-End IT Services
        </h2>
        <p class="font-outfit text-on-surface-variant text-lg leading-relaxed">
          From strategy to execution, we cover the full spectrum of technology needs for businesses ready to grow.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((service, i) => (
          <ServiceCard 
            title={service.title}
            description={service.description}
            icon={service.icon}
            href={`/services#${service.slug}`}
            featured={i === 0}
          />
        ))}
      </div>

      <div class="mt-12 text-left md:text-center">
        <Button variant="ghost" href="/services" label="View All Services" icon={true} />
      </div>
    </div>
  </section>

  <!-- About / Rooted in Jamaica -->
  <section class="py-24 bg-surface" aria-labelledby="about-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Text -->
        <div>
          <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">About Paradigm IT</span>
          <h2 id="about-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight mb-8">
            Built for Caribbean Business
          </h2>
          <p class="font-outfit text-on-surface-variant text-lg leading-relaxed mb-6">
            Founded in Kingston, Jamaica, Paradigm IT Services understands the unique challenges facing Caribbean businesses — the infrastructure constraints, the talent gaps, and the fierce competition with global companies.
          </p>
          <p class="font-outfit text-on-surface-variant text-lg leading-relaxed mb-8">
            We combine global best practices with local expertise, delivering enterprise-grade IT solutions at prices that make sense for regional businesses.
          </p>
          <Button variant="secondary" href="/about" label="Our Story" />
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-6">
          <div class="p-8 bg-white border-l-4 border-primary">
            <p class="font-fraunces font-bold text-primary text-5xl mb-2">50+</p>
            <p class="font-space text-xs uppercase tracking-wider text-on-surface-variant">Caribbean Businesses Served</p>
          </div>
          <div class="p-8 bg-white border-l-4 border-secondary">
            <p class="font-fraunces font-bold text-secondary text-5xl mb-2">10+</p>
            <p class="font-space text-xs uppercase tracking-wider text-on-surface-variant">Years in Operation</p>
          </div>
          <div class="p-8 bg-white border-l-4 border-tertiary">
            <p class="font-fraunces font-bold text-tertiary text-5xl mb-2">99.9%</p>
            <p class="font-space text-xs uppercase tracking-wider text-on-surface-variant">Average Uptime</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Paradigm IT -->
  <section class="py-24 bg-white" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">Why Us</span>
        <h2 id="why-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight">
          Why Choose Paradigm IT?
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Feature 1 -->
        <div class="p-6 bg-surface">
          <div class="mb-5">
            <div class="w-12 h-12 bg-primary/10 flex items-center justify-center mb-5">
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-fraunces font-semibold text-secondary text-lg mb-3">Local Expertise</h3>
            <p class="font-outfit text-on-surface-variant text-sm leading-relaxed">
              We know Caribbean business from the inside — the rhythms, the constraints, the opportunities.
            </p>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="p-6 bg-surface">
          <div class="mb-5">
            <div class="w-12 h-12 bg-secondary/10 flex items-center justify-center mb-5">
              <svg class="h-6 w-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-fraunces font-semibold text-secondary text-lg mb-3">Fast Response</h3>
            <p class="font-outfit text-on-surface-variant text-sm leading-relaxed">
              No ticket queues spanning days. Real people who pick up the phone and show up when needed.
            </p>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="p-6 bg-surface">
          <div class="mb-5">
            <div class="w-12 h-12 bg-tertiary/10 flex items-center justify-center mb-5">
              <svg class="h-6 w-6 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-fraunces font-semibold text-secondary text-lg mb-3">Enterprise Security</h3>
            <p class="font-outfit text-on-surface-variant text-sm leading-relaxed">
              Global-grade cybersecurity frameworks adapted for the specific threats facing regional businesses.
            </p>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="p-6 bg-surface">
          <div class="mb-5">
            <div class="w-12 h-12 bg-secondary-fixed/20 flex items-center justify-center mb-5">
              <svg class="h-6 w-6 text-secondary-fixed" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-fraunces font-semibold text-secondary text-lg mb-3">Transparent Pricing</h3>
            <p class="font-outfit text-on-surface-variant text-sm leading-relaxed">
              Clear, predictable costs with no hidden fees. Know exactly what you're paying and why.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-primary" aria-labelledby="cta-heading">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 id="cta-heading" class="font-fraunces font-bold text-white text-4xl md:text-5xl leading-tight mb-6">
        Ready to Transform?
      </h2>
      <p class="font-outfit font-light text-white/80 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
        Let's talk about what your business needs. No pressure, no pitch — just an honest conversation about what might work.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a 
          href={BOOKING_URL}
          class="inline-flex items-center gap-2 bg-white text-primary uppercase text-sm font-space font-semibold tracking-widest px-8 py-4 hover:bg-surface transition-colors duration-200"
        >
          Book a Meeting
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a 
          href="/services"
          class="inline-flex items-center gap-2 bg-transparent border border-white/40 text-white uppercase text-sm font-space font-semibold tracking-widest px-8 py-4 hover:bg-white/10 transition-colors duration-200"
        >
          Explore Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
