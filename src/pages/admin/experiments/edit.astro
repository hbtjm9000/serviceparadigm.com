---
layout: null
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Variant - Paradigm CMS Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <script>
    // Check authentication on page load
    if (typeof window !== 'undefined' && localStorage.getItem('admin_auth_token') !== 'paradigm2026') {
      window.location.href = '/admin/login';
    }
  </script>
  <div class="min-h-screen p-8">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="flex justify-between items-center mb-8">
        <div>
          <nav class="flex items-center text-sm text-gray-500">
            <a href="/admin/experiments" class="hover:text-gray-700">Experiments</a>
            <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <span id="breadcrumb-key" class="text-gray-900 font-medium"></span>
          </nav>
          <h1 class="text-3xl font-bold text-gray-900 mt-2">Edit Variant</h1>
        </div>
        <div class="flex space-x-3">
          <button
            id="preview-btn"
            class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
          >
            Preview
          </button>
          <button
            onclick="handleSave()"
            id="save-btn"
            class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 disabled:opacity-50"
          >
            Save Changes
          </button>
        </div>
      </div>

      <!-- Loading State -->
      <div id="loading" class="text-center py-12">
        <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
        </svg>
        <p class="mt-4 text-gray-500">Loading variant...</p>
      </div>

      <!-- Edit Form -->
      <div id="editor" class="hidden grid gap-8 lg:grid-cols-2">
        <!-- Editor Panel -->
        <div class="space-y-6">
          <div class="bg-white rounded-lg shadow border border-gray-200 p-6">
            <h2 class="text-lg font-medium text-gray-900 mb-4">Variant Details</h2>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700">Variant Key</label>
                <input
                  id="edit-key"
                  type="text"
                  disabled
                  class="mt-1 block w-full rounded-md border-gray-300 bg-gray-50 shadow-sm sm:text-sm"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700">
                  Label
                  <span class="text-gray-500 font-normal ml-1">(Internal name)</span>
                </label>
                <input
                  id="edit-label"
                  type="text"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700">
                  Headline
                  <span class="text-gray-500 font-normal ml-1">(Main hero text)</span>
                </label>
                <input
                  id="edit-headline"
                  type="text"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700">
                  Headline Highlight
                  <span class="text-gray-500 font-normal ml-1">(Emphasized word)</span>
                </label>
                <input
                  id="edit-highlight"
                  type="text"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700">
                  CTA Text
                  <span class="text-gray-500 font-normal ml-1">(Button label)</span>
                </label>
                <input
                  id="edit-cta"
                  type="text"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700">
                  Subheadline
                  <span class="text-gray-500 font-normal ml-1">(Supporting description)</span>
                </label>
                <textarea
                  id="edit-subheadline"
                  rows="4"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                ></textarea>
              </div>
            </div>
          </div>
        </div>

        <!-- Preview Panel -->
        <div class="space-y-6">
          <div class="bg-white rounded-lg shadow border border-gray-200 p-6">
            <h2 class="text-lg font-medium text-gray-900 mb-4">Live Preview</h2>
            
            <!-- Hero Preview -->
            <div class="border border-gray-200 rounded-lg overflow-hidden bg-gradient-to-br from-blue-50 to-indigo-100 p-8">
              <div class="max-w-2xl mx-auto text-center space-y-6">
                <h1 id="preview-headline" class="text-4xl font-bold text-gray-900"></h1>
                <p id="preview-subheadline" class="text-lg text-gray-600"></p>
                <button id="preview-cta" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700"></button>
              </div>
            </div>
            
            <!-- Character Counts -->
            <div class="mt-6 grid grid-cols-2 gap-4 text-sm">
              <div class="bg-gray-50 rounded-md p-3">
                <div class="text-gray-500">Headline</div>
                <div id="headline-count" class="font-medium text-gray-900">0 / 60 chars</div>
              </div>
              <div class="bg-gray-50 rounded-md p-3">
                <div class="text-gray-500">Subheadline</div>
                <div id="subheadline-count" class="font-medium text-gray-900">0 / 200 chars</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Get variant key from URL query parameter
    const urlParams = new URLSearchParams(window.location.search);
    const variantKey = urlParams.get('key');
    
    if (!variantKey) {
      alert('No variant specified');
      window.location.href = '/admin/experiments';
    }
    
    let variant = null;

    // Load variant on page load
    async function loadVariant() {
      try {
        const response = await fetch('http://localhost:4322/variants?experiment=hero&t=' + Date.now());
        if (!response.ok) {
          throw new Error('Failed to fetch variants: ' + response.statusText);
        }
        const variants = await response.json();
        
        variant = variants[variantKey];
        
        if (!variant) {
          alert('Variant not found');
          window.location.href = '/admin/experiments';
          return;
        }

        // Populate form
        document.getElementById('edit-key').value = variantKey;
        document.getElementById('edit-label').value = variant.label;
        document.getElementById('edit-headline').value = variant.headline;
        document.getElementById('edit-highlight').value = variant.headline_highlight;
        document.getElementById('edit-cta').value = variant.cta_text;
        document.getElementById('edit-subheadline').value = variant.subheadline;
        
        // Update breadcrumb
        document.getElementById('breadcrumb-key').textContent = variantKey;
        
        // Update preview
        updatePreview();
        
        // Show editor, hide loading
        document.getElementById('loading').classList.add('hidden');
        document.getElementById('editor').classList.remove('hidden');
      } catch (error) {
        alert('Failed to load variant: ' + error.message);
        console.error(error);
      }
    }

    function updatePreview() {
      const headline = document.getElementById('edit-headline').value;
      const highlight = document.getElementById('edit-highlight').value;
      const subheadline = document.getElementById('edit-subheadline').value;
      const cta = document.getElementById('edit-cta').value;

      // Split headline and highlight for styled preview
      const parts = headline.split(highlight);
      const previewHeadline = document.getElementById('preview-headline');
      
      if (parts.length === 2) {
        previewHeadline.innerHTML = `${escapeHtml(parts[0])}<span class="text-blue-600">${escapeHtml(highlight)}</span>${escapeHtml(parts[1])}`;
      } else {
        previewHeadline.textContent = headline;
      }
      
      document.getElementById('preview-subheadline').textContent = subheadline;
      document.getElementById('preview-cta').textContent = cta;

      // Update character counts
      const headlineCount = document.getElementById('headline-count');
      const subheadlineCount = document.getElementById('subheadline-count');
      
      headlineCount.textContent = headline.length + ' / 60 chars';
      subheadlineCount.textContent = subheadline.length + ' / 200 chars';
      
      headlineCount.className = 'font-medium ' + (headline.length > 60 ? 'text-red-600' : 'text-gray-900');
      subheadlineCount.className = 'font-medium ' + (subheadline.length > 200 ? 'text-red-600' : 'text-gray-900');
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function handleSave() {
      const btn = document.getElementById('save-btn');
      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        const updatedVariant = {
          label: document.getElementById('edit-label').value.trim(),
          headline: document.getElementById('edit-headline').value.trim(),
          headline_highlight: document.getElementById('edit-highlight').value.trim(),
          cta_text: document.getElementById('edit-cta').value.trim(),
          subheadline: document.getElementById('edit-subheadline').value.trim()
        };

        // Load current variants
        const response = await fetch('http://localhost:4322/variants?experiment=hero&t=' + Date.now());
        const variants = await response.json();
        
        // Update variant
        variants[variantKey] = updatedVariant;

        // Save
        const saveResponse = await fetch('http://localhost:4322/variants', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ experimentKey: 'hero', variants })
        });

        const result = await saveResponse.json();
        
        if (result.success) {
          alert('Variant saved successfully!');
          updatePreview();
        } else {
          alert('Failed to save: ' + result.error);
        }
      } catch (error) {
        alert('Failed to save variant: ' + error.message);
        console.error(error);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Changes';
      }
    }

    function handlePreview() {
      localStorage.setItem('experiment_hero_variant', variantKey);
      window.open('/', '_blank');
    }

    // Add event listeners for live preview
    ['edit-headline', 'edit-highlight', 'edit-subheadline', 'edit-cta'].forEach(id => {
      document.getElementById(id).addEventListener('input', updatePreview);
    });

    // Add event listeners for buttons
    document.getElementById('save-btn').addEventListener('click', handleSave);
    document.getElementById('preview-btn').addEventListener('click', handlePreview);

    // Initialize
    loadVariant();
  </script>
</body>
</html>
